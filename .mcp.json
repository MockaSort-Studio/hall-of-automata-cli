{
  "sequential-thinking": {
    "command": "npx",
    "args": [
      "-y",
      "@modelcontextprotocol/server-sequential-thinking"
    ]
  },
  "fetch": {
    "command": "uvx",
    "args": [
      "mcp-server-fetch"
    ]
  },
  "github": {
    "type": "http",
    "url": "https://api.githubcopilot.com/mcp/",
    "headers": {
      "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
    }
  },
  "google-drive": {
    "type": "http",
    "url": "https://drivemcp.googleapis.com/mcp/v1"
  },
  "hall-projects": {
    "command": "uv",
    "args": [
      "run",
      "--with",
      "mcp",
      "HALL_CLI_PLUGIN_ROOT/mcp/hall-projects-server.py"
    ]
  }
}
