{
  "name": "hall-of-automata-cli",
  "version": "1.1.0",
  "description": "Persistent local orchestrator for multi-task projects on the Hall of Automata. Plan, dispatch, and coordinate specialist agents via a design conversation with Old Major.",
  "author": {
    "name": "Michelangelo Setaro",
    "email": "mksetaro@gmail.com"
  },
  "repository": "https://github.com/MockaSort-Studio/hall-of-automata-cli",
  "license": "GPL-3.0",
  "keywords": [
    "hall-of-automata",
    "orchestration",
    "agents",
    "github-actions",
    "old-major"
  ],
  "skills": [
    { "name": "hall-open",          "path": "skills/hall-open/SKILL.md" },
    { "name": "hall-close",         "path": "skills/hall-close/SKILL.md" },
    { "name": "hall-plan",          "path": "skills/hall-plan/SKILL.md" },
    { "name": "hall-dispatch",      "path": "skills/hall-dispatch/SKILL.md" },
    { "name": "hall-review",        "path": "skills/hall-review/SKILL.md" },
    { "name": "hall-reconcile",     "path": "skills/hall-reconcile/SKILL.md" },
    { "name": "hall-status",        "path": "skills/hall-status/SKILL.md" },
    { "name": "hall-reply",         "path": "skills/hall-reply/SKILL.md" },
    { "name": "hall-consultations", "path": "skills/hall-consultations/SKILL.md" },
    { "name": "hall-init-board",    "path": "skills/hall-init-board/SKILL.md" },
    { "name": "hall-doctor",        "path": "skills/hall-doctor/SKILL.md" },
    { "name": "hall-prune",         "path": "skills/hall-prune/SKILL.md" }
  ],
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Skill",
      "AskUserQuestion",
      "ToolSearch",
      "TodoRead",
      "TodoWrite",
      "CronCreate",
      "CronDelete",
      "CronList",
      "ScheduleWakeup",
      "Monitor",
      "TaskCreate",
      "TaskUpdate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "NotebookEdit",
      "PushNotification",
      "RemoteTrigger",
      "mcp__github__*",
      "mcp__plugin_hall-of-automata_github__*",
      "mcp__fetch__fetch",
      "mcp__sequential-thinking__sequentialthinking"
    ]
  }
}
